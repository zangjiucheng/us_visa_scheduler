[PERSONAL_INFO]
; Account and current appointment info from https://ais.usvisa-info.com
USERNAME = account@gmail.com
PASSWORD = account_pass
; Find SCHEDULE_ID in re-schedule page link:
; https://ais.usvisa-info.com/en-am/niv/schedule/{SCHEDULE_ID}/appointment
SCHEDULE_ID = 99999999
; Target Period (YYYY-MM-DD, must be valid calendar dates):
PERIOD_START = 2027-10-01
PERIOD_END = 2027-11-30
; Change "en-am-yer", based on your embassy Abbreviation in embassy.py list.
YOUR_EMBASSY = en-am-yer
; True  = auto-book the earliest date found inside your window, then stop.
; False = only notify (you reschedule manually).
AUTO_RESCHEDULE = True

[CHROMEDRIVER]
; Details for the script to control Chrome
LOCAL_USE = True
; The NixOS service runs under xvfb-run — use HEADLESS = False there to avoid 403 blocks.
HEADLESS = False
; Optional: override browser/driver paths (set automatically on NixOS)
CHROME_BIN =
CHROMEDRIVER_PATH =
USER_AGENT =
; Stop the service after this many consecutive login failures (0 = unlimited)
MAX_LOGIN_ATTEMPTS = 3
; Optional: HUB_ADDRESS is mandatory only when LOCAL_USE = False
HUB_ADDRESS = http://localhost:9515/wd/hub

[NOTIFICATION]
; Discord bot notifications (https://discord.com/developers/applications)
; 1. Create an application -> Bot -> Reset Token -> copy DISCORD_BOT_TOKEN
; 2. Enable "Message Content Intent" under Bot settings if needed
; 3. Invite the bot to your server (OAuth2 -> URL Generator -> bot scope + Send Messages)
; 4. Right-click the target channel -> Copy Channel ID (enable Developer Mode in Discord settings)
DISCORD_BOT_TOKEN =
DISCORD_CHANNEL_ID =

[TIME]
; Time between retries/checks for available dates (seconds)
RETRY_TIME_L_BOUND = 10
RETRY_TIME_U_BOUND = 120
; Cooling down after WORK_LIMIT_TIME hours of work (Avoiding Ban)(hours)
WORK_LIMIT_TIME = 1.5
WORK_COOLDOWN_TIME = 2.25
; Temporary Banned (empty list): wait COOLDOWN_TIME (hours)
BAN_COOLDOWN_TIME = 5
